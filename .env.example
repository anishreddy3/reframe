# Server-side only. Never prefix these with NEXT_PUBLIC_.
OPENAI_API_KEY=replace_with_your_openai_key
EXA_API_KEY=replace_with_your_exa_key
# Optional. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini
# Optional in local development only; production ignores this fallback identity.
REFRAME_DEV_USER_EMAIL=evaluator@local.test
# Required only when temporary judge access is enabled.
JUDGE_ACCESS_USERNAME=replace_with_evaluator_username
JUDGE_ACCESS_PASSWORD=replace_with_evaluator_password
JUDGE_SESSION_SECRET=replace_with_at_least_32_random_characters
