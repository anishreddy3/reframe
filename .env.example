# Server-side only. Never prefix these with NEXT_PUBLIC_.
OPENAI_API_KEY=replace_with_your_openai_key
EXA_API_KEY=replace_with_your_exa_key
# Optional. Defaults to gpt-5.6-sol.
OPENAI_MODEL=gpt-5.6-sol
# Optional in local development only; production ignores this fallback identity.
REFRAME_DEV_USER_EMAIL=developer@local.test
